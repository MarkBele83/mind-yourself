<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Wear OS identification -->
    <uses-feature android:name="android.hardware.type.watch" />

    <!-- Health Services -->
    <uses-permission android:name="android.permission.BODY_SENSORS"
        android:maxSdkVersion="35" />
    <!-- Granular permissions for API 36+ (Wear OS 6) -->
    <uses-permission android:name="android.permission.READ_HEART_RATE" />
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />

    <!-- Notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Background services -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_HEALTH" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- WorkManager (required for reliable background work on Wear OS) -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Allow the app to request exemption from battery optimisation.
         Without this, Android can defer or kill WorkManager jobs when the app
         is in the restricted battery bucket, making reminders unreliable. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Watch ↔ Phone sync -->
    <uses-permission android:name="com.google.android.permission.PROVIDE_BACKGROUND" />

    <!-- Location (for named location resolution at reminder evaluation time) -->
    <!-- ACCESS_WIFI_STATE: read WLAN SSID for primary location matching -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <!-- ACCESS_FINE_LOCATION: required by Android to read WLAN SSID (API 26+) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <!-- ACCESS_COARSE_LOCATION: Cell ID fallback when WLAN is unavailable -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- READ_PHONE_STATE: required for TelephonyManager.getAllCellInfo() -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <application
        android:name=".MindYourselfWearApp"
        android:allowBackup="false"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.DeviceDefault">

        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="true" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:taskAffinity=""
            android:theme="@android:style/Theme.DeviceDefault">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- PassiveListenerService: receives batched sensor data from Health Services -->
        <service
            android:name=".service.PassiveDataService"
            android:exported="true"
            android:foregroundServiceType="health"
            android:permission="android.permission.BIND_LISTENER_SERVICE" />

        <!-- Receives data pushed from Phone via Wear Data Layer API -->
        <service
            android:name=".wear.sync.WearSyncService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.DATA_CHANGED" />
                <data
                    android:host="*"
                    android:pathPrefix="/reminder_configs"
                    android:scheme="wear" />
                <data
                    android:host="*"
                    android:pathPrefix="/vacation_settings"
                    android:scheme="wear" />
                <data
                    android:host="*"
                    android:pathPrefix="/app_settings"
                    android:scheme="wear" />
                <data
                    android:host="*"
                    android:pathPrefix="/hydration_hc_logs"
                    android:scheme="wear" />
            </intent-filter>
        </service>

        <!-- Handles taps on notification action buttons -->
        <receiver
            android:name=".receiver.NotificationActionReceiver"
            android:exported="false" />

        <!-- Re-register PassiveListenerService after device reboot -->
        <receiver
            android:name=".receiver.BootCompletedReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!--
            Disable WorkManager's auto-initializer so that WorkManager is NOT
            initialized before Application.onCreate() (where Hilt injects the
            HiltWorkerFactory into our Configuration.Provider).
            Without this, WorkManagerInitializer runs via androidx.startup
            before Hilt is ready, causing NoSuchMethodException when Workers
            with @HiltWorker/@AssistedInject are instantiated.
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>

</manifest>
