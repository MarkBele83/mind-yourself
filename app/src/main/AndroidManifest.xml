<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Watch ↔ Phone sync -->
    <uses-permission android:name="com.google.android.permission.PROVIDE_BACKGROUND" />

    <!-- Location (for capturing named location fingerprints in Settings) -->
    <!-- ACCESS_WIFI_STATE: general WiFi state access -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <!-- ACCESS_FINE_LOCATION: required to read WiFi SSID on Android 9+ -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <!-- ACCESS_COARSE_LOCATION: capture Cell IDs as location fallback fingerprint -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- READ_PHONE_STATE: required for TelephonyManager.getAllCellInfo() -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <application
        android:name=".MindYourselfApp"
        android:allowBackup="false"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.MindYourself">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Receives log data pushed from Watch via Wear Data Layer API -->
        <service
            android:name=".sync.PhoneSyncService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.DATA_CHANGED" />
                <data
                    android:host="*"
                    android:pathPrefix="/hydration_logs"
                    android:scheme="wear" />
                <data
                    android:host="*"
                    android:pathPrefix="/supplement_logs"
                    android:scheme="wear" />
                <data
                    android:host="*"
                    android:pathPrefix="/heart_rate_logs"
                    android:scheme="wear" />
            </intent-filter>
        </service>

        <!-- Health Connect permissions rationale screen (required for Play Store) -->
        <!-- TODO: <activity android:name=".PermissionsRationaleActivity" android:exported="true"> -->

    </application>

</manifest>
